[
  {
    "name" : "left-bar",
    "layer": "top",
    "position": "left",
    "modules-left" : ["custom/dualitybox"],
    "modules-right": ["custom/powerbutton"],

    "custom/dualitybox" : {
      "format" : " ",
      "tooltip" : false
    },

    "custom/powerbutton": {
        "format" : "",
        "tooltip-format" : "Shut Down",
        "on-click": "systemctl poweroff"
    }
  },
  {
    "name" : "top-bar",
    "layer": "top",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["clock"],

    "clock": {
        "format" : "{:%H:%M}",
        "format-alt" : "{:%a, %d. %b  %H:%M}",
        "tooltip" : false
    }
  }
]
